# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (Docker Compose default)
DATABASE_URL=postgresql://vermietung:vermietung@localhost:5432/vermietung?schema=public

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# Hostaway Public API
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_API_SECRET=
HOSTAWAY_API_BASE_URL=https://api.hostaway.com/v1

# fonio.ai middleware API key (fonio sends this in requests)
FONIO_API_KEY=

# Admin JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Initial admin (created on first boot if no admin exists)
ADMIN_EMAIL=admin@brainions.digital
ADMIN_PASSWORD=

# Log retention (days)
LOG_RETENTION_DEBUG_DAYS=14
LOG_RETENTION_OPERATIONAL_DAYS=30
LOG_RETENTION_PII_DAYS=30

PRODUCTION_URL=https://vermietung.brainions.digital

SYNC_ENABLED=true

HOSTAWAY_WEBHOOK_USERNAME=
HOSTAWAY_WEBHOOK_PASSWORD=
