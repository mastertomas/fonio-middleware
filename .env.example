# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
PRODUCTION_URL=https://vermietung.brainions.digital

# Database
DATABASE_URL=postgresql://vermietung:vermietung@localhost:5432/vermietung?schema=public

# Redis (reserved)
REDIS_URL=redis://localhost:6379

# Hostaway Public API (server-side only — never expose to frontend)
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_API_SECRET=
HOSTAWAY_API_BASE_URL=https://api.hostaway.com/v1

# fonio.ai middleware API key (server-side only)
FONIO_API_KEY=

# Admin JWT (change before production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Initial admin (created on first boot if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Log retention (days) — GDPR-conscious audit logs (see docs/SECURITY.md)
LOG_RETENTION_DEBUG_DAYS=14
LOG_RETENTION_OPERATIONAL_DAYS=30
LOG_RETENTION_PII_DAYS=30
LOG_RETENTION_MAX_DAYS=90

# Production security
# FORCE_HTTPS=true
# SWAGGER_ENABLED=true

# Sync
SYNC_ENABLED=true

# Hostaway webhook basic auth (recommended in production)
HOSTAWAY_WEBHOOK_USERNAME=
HOSTAWAY_WEBHOOK_PASSWORD=

# Performance tuning (optional — see docs/DEPLOYMENT.md)
# CONVERSATION_BACKFILL_ON_SYNC=true
